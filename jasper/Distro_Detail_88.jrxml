<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Distro_Detail" language="groovy" pageWidth="612" pageHeight="792" whenNoDataType="BlankPage" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d8510694-f729-40c8-bdcb-fe46a7d8b813">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.governor.max.pages" value="9999999"/>
	<property name="net.sf.jasperreports.governor.max.pages.enabled" value="true"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PROD"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="a_tc_shipment_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select distinct d.tc_order_id,
    d.parent_order_id,
    f.dsp_sku,
    f.sku_desc,
    sum(i.size_value) pakd_qty,
    d.d_facility_alias_id,
    d.d_facility_name,
    d.o_facility_alias_id,
    d.o_facility_name,
    g.description do_status,
    a.tc_shipment_id,
    f.unit_price,
    f.retail_price,
    h.quantity,
    sum(i.size_value/h.quantity) collie,
    case when order_type='X' then 'X-Dock' else 'Reguler' end as order_type,
    trunc(max(b.loaded_dttm)) loaded_date,
    a.assigned_ship_via ship_via,
    a.trailer_number,
    a.trlr_type||trlr_size Countainer_type,
    substr(a.assigned_ship_via,1,1) Trans_type,
    a.seal_number
from shipment a,
    outpt_lpn b,
    outpt_order_line_item c,
    orders d,
    item_master f,
    do_status g,
    item_package_cbo h,
    outpt_lpn_detail i
where a.tc_shipment_id=b.tc_shipment_id
and b.invc_batch_nbr=c.invc_batch_nbr
and c.item_id=f.item_id
and c.tc_order_id=d.tc_order_id
and b.tc_order_id=d.parent_order_id
and d.do_status=g.order_status
and c.item_id=h.item_id
and f.item_id=h.item_id
and b.tc_lpn_id=i.tc_lpn_id
and LINE_ITEM_ID=DISTRIBUTION_ORDER_DTL_ID
and c.shipped_qty>0
and h.PACKAGE_UOM_ID='46'
and h.is_std='1'
and h.MARK_FOR_DELETION='0'
$P!{a_tc_shipment_id}
group by  d.tc_order_id,
    d.parent_order_id,
    f.dsp_sku,
    f.sku_desc,
    d.d_facility_alias_id,
    d.d_facility_name,
    d.o_facility_alias_id,
    d.o_facility_name,
    g.description,
    a.tc_shipment_id,
    f.unit_price,
    f.retail_price,
    h.quantity,
    d.order_type,
    a.assigned_ship_via,
    trailer_number,
    a.trlr_type||trlr_size,
    substr(a.assigned_ship_via,1,1),
    a.seal_number
order by a.tc_shipment_id,d.tc_order_id,dsp_sku]]>
	</queryString>
