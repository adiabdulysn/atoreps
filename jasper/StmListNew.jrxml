<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="StmList_Cib" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="510fbbac-65c1-48c7-b13e-0960a88c5dc1">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="WMC"/>
	<parameter name="TC_SHIPMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
	DISTINCT OL.C_FACILITY_ALIAS_ID WH,
	OL.FINAL_DEST_FACILITY_ALIAS_ID STORE,
	FA.FACILITY_NAME STORE_NAME,
	L.MINOR_ORDER_NBR STM_NBR,
	L.TC_LPN_ID OB_CTN,
	L.ITEM_NAME SKU,
	IC.DESCRIPTION SKU_DESC,
	DECODE(L.QTY_UOM, 'U', 'Units', 'H', 'Hecto')UOM,
	IPC.QUANTITY STD,
	L.SIZE_VALUE SHIP_QTY,
	OL.MISC_NUM_1 COLLIE,
	OL.TC_SHIPMENT_ID,
	to_char(L.SHIP_DATE,'DD-Mon-YYYY') SHIP_DATE
FROM
	(
	SELECT
		DISTINCT OLD.INVC_BATCH_NBR,
		OLD.MINOR_ORDER_NBR,
		OLD.TC_LPN_ID,
		OLD.ITEM_NAME,
		OLD.QTY_UOM,
		OLD.SIZE_VALUE,
		TRUNC(OLD.LAST_UPDATED_DTTM)SHIP_DATE,
		OLD.LAST_UPDATED_SOURCE
	FROM
		OUTPT_LPN_DETAIL OLD,
		OUTPT_LPN OL
	WHERE
		OLD.INVC_BATCH_NBR = OL.INVC_BATCH_NBR) L,
	OUTPT_LPN OL,
	ITEM_CBO IC,
	ITEM_PACKAGE_CBO IPC,
	FACILITY_ALIAS FA
WHERE
	L.TC_LPN_ID = OL.TC_LPN_ID
	AND L.INVC_BATCH_NBR = OL.INVC_BATCH_NBR
	AND L.ITEM_NAME = IC.ITEM_NAME(+)
	AND IC.ITEM_ID = IPC.ITEM_ID(+)
	AND OL.FINAL_DEST_FACILITY_ALIAS_ID = FA.FACILITY_ALIAS_ID
	AND OL.PROC_STAT_CODE = '90'
	AND IC.MARK_FOR_DELETION = '0'
	AND IPC.MARK_FOR_DELETION = '0'
	AND IPC.IS_STD = '1'
	AND IPC.PACKAGE_UOM_ID = '46'
	$P!{TC_SHIPMENT_ID}
ORDER BY
	OL.FINAL_DEST_FACILITY_ALIAS_ID,
	L.MINOR_ORDER_NBR,
	L.TC_LPN_ID]]>
	</queryString>
