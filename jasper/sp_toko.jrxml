	<parameter name="a_tc_shipment_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.TC_SHIPMENT_ID,O_FACILITY_ALIAS_ID DC,O_FACILITY_NAME DC_NAME,
'Kawasan,Graha_Raharja_Balaraja,Industrial_Estate,Kp.petuey,Desa_Tobat,Kec_Balaraja,TANGERANG'DC_ADRESS,
case when  PICK_LOCN_ASSIGN_TYPE in ('DPL','DPS','DOL','DOS','LOL','LOS','DTL','DTS','DGL','DGS','DKL','LKZ','DKS','LKL','DNL','DNS','LNL','LNS','LNZ') then'FP.01.04/IV/0032-e/2020'
             when PICK_LOCN_ASSIGN_TYPE in ('ABS','AKB','AKD','AKL','AKN','AKS','AKZ') then'FK.01.01/VI/1663-e/2020' end PBF,'021-5952075'DC_TELP,f.FACILITY_ID,c.D_FACILITY_ALIAS_ID STORE,FINAL_DEST_FACILITY_ALIAS_ID Toko,c.D_FACILITY_NAME Store_name,
SUBSTR(comments,INSTR(comments,'PIC:')+4,INSTR(comments,CHR(10),1,1)-INSTR(comments,'PIC:')-4) APOTEKER
        , SUBSTR(comments,INSTR(comments,'Nomor1:')+7,INSTR(comments,CHR(10),1,2)-INSTR(comments,'Nomor1:')-7) NO_SITOizin_Usaha
        , SUBSTR(comments,INSTR(comments,'Nomor2:')+7,INSTR(comments,CHR(10),1,3)-INSTR(comments,'Nomor2:')-7) NO_IKTTK_SIPA
        , SUBSTR(comments,INSTR(comments,'Jenis:')+6) jenis,TELEPHONE_NUMBER,f.ADDRESS_1,f.ADDRESS_2,f.CITY,f.STATE_PROV,f.ADDRESS_3,case when f.ADDRESS_1 in('JL','jl','Mall''NO','No','no data','NO DATA','-') or f.ADDRESS_1 is null then g.ADDRESS_2 ELSE f.ADDRESS_1||', '||f.ADDRESS_2||', '||f.ADDRESS_3 END AS ADDRESS
        ,c.TC_ORDER_ID,d.ITEM_NAME,d.DESCRIPTION,
        PICK_LOCN_ASSIGN_TYPE,COMMERCE_ATTRIBUTE1 ZAT_AKTIF_Prekursor_Farmasi,
COMMERCE_ATTRIBUTE2 Bentuk_dan_Kekuatan_sediaan,
case when d.BASE_STORAGE_UOM_ID ='657'then 'Pcs'
             when d.BASE_STORAGE_UOM_ID ='281' then 'Hecto' end Satuan,
b.SIZE_VALUE  QTY,mppa_dc.terbilang(b.SIZE_VALUE) terbilang,to_char(a.LAST_UPDATED_DTTM,'dd-Mon-yyyy') LAST_UPDATED,
   case when e.PICK_LOCN_ASSIGN_TYPE in ('DPL','DPS') then 'Surat pesanan  Obat mengandung Prekursor Farmasi'
        when e.PICK_LOCN_ASSIGN_TYPE in ('DOL','DOS','LOL','LOS') then 'Surat pesanan  Obat Non Prekursor Farmasi'
        when e.PICK_LOCN_ASSIGN_TYPE in ('ABS','AKB','AKD','AKL','AKN','AKS','AKZ') then 'Surat pesanan  Alat Kesehatan Farmasi'
        when e.PICK_LOCN_ASSIGN_TYPE in ('DTL','DTS') then 'Surat pesanan  Obat Obat Tertentu'
        when e.PICK_LOCN_ASSIGN_TYPE in ('DGL','DGS','DKL','LKZ','DKS','LKL') then 'Surat pesanan  Obat Keras'
        when e.PICK_LOCN_ASSIGN_TYPE in ('DNL','DNS','LNL','LNS','LNZ') then 'Surat pesanan Non Obat'end  Surat_Pesanan,
case when  PICK_LOCN_ASSIGN_TYPE in ('DPL','DPS','DOL','DOS','LOL','LOS','DTL','DTS','DGL','DGS','DKL','LKZ','DKS','LKL','DNL','DNS','LNL','LNS','LNZ') then'Nama PBF'
             when PICK_LOCN_ASSIGN_TYPE in ('ABS','AKB','AKD','AKL','AKN','AKS','AKZ') then'Nama PAK' end nama,
   case when  PICK_LOCN_ASSIGN_TYPE in ('DPL','DPS','DOL','DOS','LOL','LOS','DTL','DTS','DGL','DGS','DKL','LKZ','DKS','LKL','DNL','DNS','LNL','LNS','LNZ') then'Izin PBF'
             when PICK_LOCN_ASSIGN_TYPE in ('ABS','AKB','AKD','AKL','AKN','AKS','AKZ') then'Izin PAK' end izin
from outpt_lpn a,outpt_lpn_detail b, outpt_orders c,item_cbo d,item_facility_mapping_wms e,facility_alias f,facility_contact g
where a.TC_LPN_ID=b.TC_LPN_ID
and a.INVC_BATCH_NBR=b.INVC_BATCH_NBR
and b.INVC_BATCH_NBR=c.INVC_BATCH_NBR
and a.INVC_BATCH_NBR=c.INVC_BATCH_NBR
and b.MINOR_ORDER_NBR=c.tc_order_id
and b.item_id=d.item_id
and b.item_id=e.item_id
and d.item_id=e.item_id
and FINAL_DEST_FACILITY_ALIAS_ID=f.FACILITY_ALIAS_ID
and f.FACILITY_ID=g.FACILITY_ID (+)
and e.FACILITY_ID='126'
and substr(d.ITEM_NAME,1,2)='68'
$P!{a_tc_shipment_id}
and O_FACILITY_ALIAS_ID ='104'
order by Surat_Pesanan]]>
	</queryString>
